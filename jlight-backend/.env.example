# JLIGHT v4 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/jlight

# Flask
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-to-something-random-and-long

# Port
PORT=5000

# CORS - add your frontend domain
ALLOWED_ORIGINS=https://jlight-health.co.za,http://localhost:3000
